                "I have time. And I genuinely want to hear 💛"
            ]
        }
    };

    // Emotion → mood label mapping
    const MOOD_LABELS = {
        tired:'😴 Tired', sad:'😔 Sad', happy:'😊 Happy', angry:'🔥 Angry',
        stress:'😰 Stressed', lonely:'🥺 Lonely', sleep:'🌙 Sleepless',
        relax:'🌿 Calm', advice:'💡 Thinking', smile:'😄 Cheerful', general:null
    };

    // Context-aware suggestion chips per emotion
    const CHIPS = {
        tired:   ['Mentally tired too', 'Give me rest tips', 'I keep feeling this way'],
        sad:     ['I just need to vent', 'Tell me it gets better', 'Help me feel better'],
        happy:   ['I want to keep this feeling', 'Suggest something fun', 'Tell me something nice'],
        angry:   ['Help me calm down', 'I need to vent', 'What should I do?'],
        stress:  ['Help me breathe', 'I need to prioritize', 'Give me a quick fix'],
        lonely:  ['Talk to me more', 'How do I feel less alone?', 'I want to connect'],
        sleep:   ['Give me sleep tips', 'Guide me through breathing', 'Calm my mind'],
        relax:   ['Guide me through breathing', 'Suggest music', 'Quick 5-min exercise'],
        advice:  ['Break it down for me', 'Help me decide', 'What would you do?'],
        smile:   ['Tell me a joke', 'Send a hug 🤗', 'Give me a fun fact'],
        general: ['I feel the same', 'What should I do?', 'Just talk to me 💛']
    };

    let _lastCategory = null;
    const _lastUsed = {};

    function pick(arr, key) {
        const last = _lastUsed[key] ?? -1;
        let idx;
        do { idx = Math.floor(Math.random() * arr.length); } while (arr.length > 1 && idx === last);
        _lastUsed[key] = idx;
        return arr[idx];
    }

    function detectCategory(text) {
        const t = text.toLowerCase();
        if (/tired|exhaust|fatigue|drained|worn out|no energy|sleepy|low energy/.test(t)) return 'tired';
        if (/sad|upset|cry|depressed|broken|hurt|miss|mourn|grief|lost|unhappy|miserable/.test(t)) return 'sad';
        if (/happy|great|awesome|amazing|fantastic|wonderful|good mood|joy|excited|love this/.test(t)) return 'happy';
        if (/angry|anger|frustrat|irritat|furious|mad|annoyed|pissed|rage/.test(t))   return 'angry';
        if (/stress|pressure|overwhelm|burden|too much|anxiety|anxious|tense/.test(t)) return 'stress';
        if (/alone|lonely|nobody|no one|isolated|no friends|left out/.test(t))         return 'lonely';
        if (/sleep|insomnia|can't sleep|no sleep|awake|wake up|insomniac/.test(t))     return 'sleep';
        if (/relax|calm|breathe|peace|meditat|unwind|chill/.test(t))                   return 'relax';
        if (/advice|help|suggest|tip|what should|what do|guide|how to|decision/.test(t)) return 'advice';
        if (/smile|laugh|fun|joke|cheer|entertain|bored/.test(t))                      return 'smile';
        return 'general';
    }

    function smartReply(text) {
        const category = detectCategory(text);
        const layer    = LAYERS[category];
        const name     = userName ? userName.split(' ')[0] : '';

        // Check repeat mood from localStorage — feel like you remember them
        const lastMood    = localStorage.getItem('mc_lastMood') || '';
        const lastMoodMsg = localStorage.getItem('mc_lastMoodMsg') || '';
        let repeatNotice  = '';
        if (lastMood && lastMood === category && lastMoodMsg !== text) {
            const notices = [
                `Still feeling ${category} ah ${name}? Yesterday same sonna 😔 everything okay?`,
                `Noticed you've been feeling this way lately… want to talk about what's really going on? 💛`,
                `Repeatedly feeling ${category} tells me something deeper might be there da. Sollu 🤝`
            ];
            repeatNotice = pick(notices, 'repeat_' + category) + '\n';
        }
        localStorage.setItem('mc_lastMood', category);
        localStorage.setItem('mc_lastMoodMsg', text);

        const e = pick(layer.empathy,  'e_' + category);
        const s = pick(layer.support,  's_' + category);
        const f = pick(layer.followup, 'f_' + category);

        // Weave into one natural flowing reply — no robotic transitions
        const reply = `${repeatNotice}${e}\n${s}\n${f}`;

        _lastCategory = category;
        return { reply, mood: MOOD_LABELS[category] };
    }

    // ----------------------------------------------------------------
    // SEND MESSAGE
    // ----------------------------------------------------------------
    sendBtn.addEventListener('click', () => sendMessage());
    chatInput.addEventListener('keypress', e => { if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendMessage(); } });

    async function sendMessage(overrideText) {
        const text = (overrideText || chatInput.value || '').trim();
        if (!text) return;

        chatInput.value = '';
        suggestionsRow.innerHTML = '';
        ensureDefaultChat();

        const chat = getActiveChat();
        if (!chat) return;

        // Auto-title on first message
        if (chat.messages.length === 0) {
            chat.title = text.length > 22 ? text.slice(0, 22) + '…' : text;
            renderChatList();
        }

        // Push to state
        chat.messages.push({ role: 'user', content: text });
        chat.updatedAt = Date.now();
        saveToStorage('mc_chats', chats);

        // Render user bubble
        appendUserMsg(text);

        // Show typing
        typingWrap.style.display = 'block';
        scrollToBottom();

        // Build history for API (last 10 turns, exclude latest user msg already pushed)
        const historyForApi = chat.messages.slice(-11, -1);

        let reply = null;
        let mood  = null;

        try {
            const resp = await fetch('/chat', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ message: text, history: historyForApi })
            });

            if (!resp.ok) throw new Error(`HTTP ${resp.status}`);

            const data = await resp.json();

            // Safely extract reply
            reply = (data.response && typeof data.response === 'string' && data.response.trim())
                ? data.response.trim()
                : null;
            mood  = (data.mood && typeof data.mood === 'string') ? data.mood : null;

        } catch (err) {
            console.warn('[MindCare] API unavailable, using smart local reply.');
        }

        // Smart keyword fallback — fires when API fails OR returns empty
        if (!reply) {
            const local = smartReply(text);
            reply = local.reply;
            if (!mood) mood = local.mood;
        }

        // Natural delay — makes it feel human
        await new Promise(r => setTimeout(r, 600 + Math.random() * 500));

        // Hide typing
        typingWrap.style.display = 'none';

        // Show reply
        appendAiMsg(reply);

        // Update mood label
        if (mood) {
            popupMoodLabel.textContent = `Mood detected: ${mood}`;
            // Update home mood display
            currentMoodText.textContent = mood;
            currentMoodDisplay.style.display = 'inline-flex';
        }

        // Save AI message
        chat.messages.push({ role: 'assistant', content: reply });
        chat.updatedAt = Date.now();
        saveToStorage('mc_chats', chats);
        renderChatList();

        // Smart suggestions
        showSuggestions();

        // Silent mood log
        silentSaveMood(mood, text);
    }

    function showSuggestions() {
        suggestionsRow.innerHTML = '';
        // Use context-specific chips based on last detected emotion
        const chips = (_lastCategory && CHIPS[_lastCategory]) ? CHIPS[_lastCategory] : CHIPS.general;
        chips.forEach(opt => {
            const btn = document.createElement('button');
            btn.className = 'suggestion-chip';
            btn.textContent = opt;
            btn.addEventListener('click', () => { suggestionsRow.innerHTML = ''; sendMessage(opt); });
            suggestionsRow.appendChild(btn);
        });
    }

    // ----------------------------------------------------------------
    // SILENT MOOD SAVE
    // ----------------------------------------------------------------
    async function silentSaveMood(moodStr, note) {
        let moodKey = 'Neutral';
        if (moodStr) {
            const m = moodStr.toLowerCase();
            if (m.includes('stress') || m.includes('anxi')) moodKey = 'Stressed';
            else if (m.includes('sad') || m.includes('low'))   moodKey = 'Sad';
            else if (m.includes('happy') || m.includes('joy')) moodKey = 'Happy';
            else if (m.includes('calm') || m.includes('peace'))moodKey = 'Calm';
            else if (m.includes('angry') || m.includes('angr'))moodKey = 'Angry';
            else if (m.includes('tired') || m.includes('exhaust')) moodKey = 'Tired';
        }
        try {
            await fetch('/save_mood', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ mood: moodKey, note: note || '' })
            });
            loadStreak();
        } catch (_) {}
    }

    // ----------------------------------------------------------------
    // VOICE INPUT
    // ----------------------------------------------------------------
    const SR = window.SpeechRecognition || window.webkitSpeechRecognition;
    if (SR) {
        const recog = new SR();
        recog.continuous = false;
        recog.interimResults = false;
        recog.lang = 'en-IN'; // Tamil-English friendly

        let recording = false;
        micBtn.addEventListener('click', () => {
            if (recording) { recog.stop(); return; }
            try { recog.start(); } catch (e) { console.warn('Speech start error', e); }
        });
        recog.onstart = () => { recording = true; micBtn.classList.add('recording'); chatHint.textContent = 'Listening… speak now 🎙️'; };
        recog.onresult = e => { chatInput.value += (chatInput.value ? ' ' : '') + e.results[0][0].transcript; };
        recog.onerror = () => reset();
        recog.onend  = () => reset();
        function reset() { recording = false; micBtn.classList.remove('recording'); chatHint.textContent = "You can talk about anything… I'm here 💛"; }
    } else {
        micBtn.style.display = 'none';
    }

    // ----------------------------------------------------------------
    // DASHBOARD
    // ----------------------------------------------------------------
    openDashboardBtn.addEventListener('click', openDashboard);
    closeDashboardBtn.addEventListener('click', () => dashboardOverlay.style.display = 'none');

    async function openDashboard() {
        dashboardOverlay.style.display = 'flex';
        try {
            const [sumData, moodData] = await Promise.all([
                fetch('/weekly_summary').then(r => r.json()),
                fetch('/get_moods').then(r => r.json())
            ]);
            weeklyInsightText.textContent = sumData.summary || 'No data yet.';
            if (streakCount) streakCount.textContent = moodData.streak || 1;
            renderMoodChart(moodData.moods || []);
        } catch (_) {
            weeklyInsightText.textContent = 'Could not load data.';
        }
    }

    function renderMoodChart(moods) {
        const canvas = document.getElementById('mood-chart');
        if (!canvas) return;
        const dist = { Happy:0, Calm:0, Neutral:0, Stressed:0, Sad:0, Angry:0, Tired:0 };
        moods.forEach(m => { if (dist[m.mood] !== undefined) dist[m.mood]++; });
        if (moodChartInst) moodChartInst.destroy();
        moodChartInst = new Chart(canvas.getContext('2d'), {
            type: 'bar',
            data: {
                labels: Object.keys(dist),
                datasets: [{ data: Object.values(dist), backgroundColor: '#A78BFA', borderRadius: 8, borderWidth: 0 }]
            },
            options: {
                responsive: true,
                plugins: { legend: { display: false } },
                scales: { y: { beginAtZero: true, ticks: { precision: 0 } } }
            }
        });
    }

    async function loadStreak() {
        try {
            const d = await fetch('/get_moods').then(r => r.json());
            if (streakCount) streakCount.textContent = d.streak || 1;
        } catch (_) {}
    }

    // ----------------------------------------------------------------
    // PARTNER CONNECT
    // ----------------------------------------------------------------
    connectBtn.addEventListener('click', () => partnerOverlay.style.display = 'flex');
    sidebarPartnerBtn.addEventListener('click', () => { closeSidebar(); partnerOverlay.style.display = 'flex'; });
    closePartnerBtn.addEventListener('click', () => partnerOverlay.style.display = 'none');

    // ----------------------------------------------------------------
    // UTILITY
    // ----------------------------------------------------------------
    function escHtml(str) {
        return String(str)
            .replace(/&/g,'&amp;')
            .replace(/</g,'&lt;')
            .replace(/>/g,'&gt;')
            .replace(/"/g,'&quot;');
    }

}); // END DOMContentLoaded
