/* ================================================================
   MINDCARE ULTRA+ — main.js
   Clean, separated, bulletproof
   ================================================================ */
document.addEventListener('DOMContentLoaded', () => {

    // ----------------------------------------------------------------
    // DOM REFERENCES
    // ----------------------------------------------------------------
    const authOverlay        = document.getElementById('auth-overlay');
    const usernameInput      = document.getElementById('username-input');
    const loginBtn           = document.getElementById('login-btn');

    const homePage           = document.getElementById('home-page');
    const heroName           = document.getElementById('hero-name');
    const streakCount        = document.getElementById('streak-count');
    const themeBtn           = document.getElementById('theme-btn');
    const openDashboardBtn   = document.getElementById('open-dashboard-btn');
    const openSidebarBtn     = document.getElementById('open-sidebar-btn');

    const moodRow            = document.getElementById('mood-row');
    const currentMoodDisplay = document.getElementById('current-mood-display');
    const currentMoodText    = document.getElementById('current-mood-text');

    const quickCards         = document.querySelectorAll('.quick-card');
    const connectBtn         = document.getElementById('connect-btn');

    const chatFab            = document.getElementById('chat-fab');
    const fabBadge           = document.getElementById('fab-badge');

    const sidebar            = document.getElementById('sidebar');
    const sidebarOverlay     = document.getElementById('sidebar-overlay');
    const closeSidebarBtn    = document.getElementById('close-sidebar-btn');
    const newChatBtn         = document.getElementById('new-chat-btn');
    const chatList           = document.getElementById('chat-list');
    const sidebarPartnerBtn  = document.getElementById('sidebar-partner-btn');

    const chatPopup          = document.getElementById('chat-popup');
    const closeChatBtn       = document.getElementById('close-chat-btn');
    const popupSidebarBtn    = document.getElementById('popup-sidebar-btn');
    const popupMoodLabel     = document.getElementById('popup-mood-label');

    const chatMessages       = document.getElementById('chat-messages');
    const typingWrap         = document.getElementById('typing-wrap');
    const suggestionsRow     = document.getElementById('suggestions-row');
    const chatInput          = document.getElementById('chat-input');
    const sendBtn            = document.getElementById('send-btn');
    const micBtn             = document.getElementById('mic-btn');
    const chatHint           = document.getElementById('chat-hint');

    const dashboardOverlay   = document.getElementById('dashboard-overlay');
    const closeDashboardBtn  = document.getElementById('close-dashboard-btn');
    const weeklyInsightText  = document.getElementById('weekly-insight-text');

    const partnerOverlay     = document.getElementById('partner-overlay');
    const closePartnerBtn    = document.getElementById('close-partner-btn');

    // ----------------------------------------------------------------
    // STATE
    // ----------------------------------------------------------------
    const COLORS = ['#5B7CFA','#A78BFA','#F472B6','#34D399','#FBBF24'];
    let userName     = '';
    let chats        = [];
    let activeChatId = null;
    let chatOpen     = false;
    let moodChartInst = null;

    // ----------------------------------------------------------------
    // HELPERS — safe localStorage
    // ----------------------------------------------------------------
    function loadFromStorage(key, fallback) {
        try {
            const raw = localStorage.getItem(key);
            if (!raw || raw === 'undefined' || raw === 'null') return fallback;
            return JSON.parse(raw);
        } catch (_) { return fallback; }
    }

    function saveToStorage(key, val) {
        try { localStorage.setItem(key, JSON.stringify(val)); } catch (_) {}
    }

    // ----------------------------------------------------------------
    // BOOT
    // ----------------------------------------------------------------
    userName = loadFromStorage('mc_username', '');
    chats    = loadFromStorage('mc_chats', []);
    if (!Array.isArray(chats)) chats = [];

    const savedTheme = loadFromStorage('mc_theme', 'light');
    document.documentElement.setAttribute('data-theme', savedTheme);
    if (themeBtn) themeBtn.textContent = savedTheme === 'dark' ? '☀️' : '🌙';

    if (userName) {
        showHomePage();
    } else {
        authOverlay.style.display = 'flex';
    }

    // ----------------------------------------------------------------
    // AUTH
    // ----------------------------------------------------------------
    loginBtn.addEventListener('click', doLogin);
    usernameInput.addEventListener('keypress', e => { if (e.key === 'Enter') doLogin(); });

    function doLogin() {
        const val = (usernameInput.value || '').trim();
        if (!val) { usernameInput.focus(); return; }
        userName = val;
        saveToStorage('mc_username', userName);
        authOverlay.style.display = 'none';
        showHomePage();
    }

    function showHomePage() {
        homePage.style.display = 'block';
        if (heroName) heroName.textContent = userName;
        ensureDefaultChat();
        renderChatList();
        loadStreak();
    }

    // ----------------------------------------------------------------
    // THEME
    // ----------------------------------------------------------------
    themeBtn.addEventListener('click', () => {
        const current = document.documentElement.getAttribute('data-theme') || 'light';
        const next = current === 'dark' ? 'light' : 'dark';
        document.documentElement.setAttribute('data-theme', next);
        themeBtn.textContent = next === 'dark' ? '☀️' : '🌙';
        saveToStorage('mc_theme', next);
    });

    // ----------------------------------------------------------------
    // CHAT MANAGEMENT
    // ----------------------------------------------------------------
    function randomColor() { return COLORS[Math.floor(Math.random() * COLORS.length)]; }

    function ensureDefaultChat() {
        if (chats.length === 0) {
            createChat(false); // silent — don't open popup
        }
        if (!activeChatId && chats.length > 0) {
            activeChatId = chats[0].id;
        }
    }

    function createChat(openPopup = true) {
        // Don't create another empty chat if one already exists
        const existingEmpty = chats.find(c => c.messages.length === 0);
        if (existingEmpty) {
            activeChatId = existingEmpty.id;
            renderChatList();
            if (openPopup) openChat();
            return;
        }
        const id = Date.now().toString(36) + Math.random().toString(36).slice(2, 7);
        const chat = { id, title: 'New Conversation', messages: [], updatedAt: Date.now(), color: randomColor() };
        chats.unshift(chat);
        activeChatId = id;
        saveToStorage('mc_chats', chats);
        renderChatList();
        if (openPopup) openChat();
    }

    function switchChat(id) {
        activeChatId = id;
        renderChatList();
        renderMessages();
        closeSidebar();
        if (!chatOpen) openChat();
    }

    function deleteChat(id) {
        if (!confirm('Delete this conversation?')) return;
        chats = chats.filter(c => c.id !== id);
        if (activeChatId === id) {
            activeChatId = chats.length > 0 ? chats[0].id : null;
            if (!activeChatId) createChat(false);
        }
        saveToStorage('mc_chats', chats);
        renderChatList();
        renderMessages();
    }

    function renameChat(id) {
        const chat = chats.find(c => c.id === id);
        if (!chat) return;
        const newTitle = prompt('Rename conversation:', chat.title);
        if (newTitle && newTitle.trim()) {
            chat.title = newTitle.trim();
            saveToStorage('mc_chats', chats);
            renderChatList();
        }
    }

    function getActiveChat() { return chats.find(c => c.id === activeChatId) || null; }

    // ----------------------------------------------------------------
    // RENDER SIDEBAR CHAT LIST
    // ----------------------------------------------------------------
    function renderChatList() {
        chatList.innerHTML = '';
        const sorted = [...chats].sort((a,b) => b.updatedAt - a.updatedAt);
        if (sorted.length === 0) {
            chatList.innerHTML = '<div style="padding:20px; color:var(--text-light); font-size:13px; text-align:center;">No conversations yet.<br>Start a new chat! 💬</div>';
            return;
        }
        sorted.forEach(chat => {
            const el = document.createElement('div');
            el.className = 'chat-item' + (chat.id === activeChatId ? ' active' : '');
            const preview = chat.messages.length
                ? (chat.messages[chat.messages.length-1].content.slice(0,30) + (chat.messages[chat.messages.length-1].content.length > 30 ? '…' : ''))
                : 'No messages yet';
            el.innerHTML = `
                <div class="chat-item-name">
                    <span class="chat-dot" style="background:${chat.color}"></span>
                    ${escHtml(chat.title)}
                </div>
                <div class="chat-item-preview">${escHtml(preview)}</div>
                <div class="chat-actions">
                    <button class="rename-btn" title="Rename">✏️</button>
                    <button class="delete-btn" title="Delete">🗑️</button>
                </div>
            `;
            el.addEventListener('click', () => switchChat(chat.id));
            el.querySelector('.rename-btn').addEventListener('click', e => { e.stopPropagation(); renameChat(chat.id); });
            el.querySelector('.delete-btn').addEventListener('click', e => { e.stopPropagation(); deleteChat(chat.id); });
            chatList.appendChild(el);
        });
    }

    // ----------------------------------------------------------------
    // RENDER MESSAGES
    // ----------------------------------------------------------------
    function renderMessages() {
        chatMessages.innerHTML = '';
        suggestionsRow.innerHTML = '';
        typingWrap.style.display = 'none';
        popupMoodLabel.textContent = 'Ready to talk 💛';

        const chat = getActiveChat();
        if (!chat || chat.messages.length === 0) {
            appendAiMsg(`Hi ${userName}! 👋 How are you feeling today? You can type anything or pick a mood from the home page.`);
            return;
        }
        chat.messages.forEach(m => {
            if (m.role === 'user') appendUserMsg(m.content, false);
            else appendAiMsg(m.content, false);
        });
        scrollToBottom();
    }

    function appendAiMsg(text, animate = true) {
        const el = document.createElement('div');
        el.className = 'msg ai-msg' + (animate ? ' scale-in' : '');
        el.innerHTML = `<div class="bubble">${escHtml(text)}</div>`;
        chatMessages.appendChild(el);
        scrollToBottom();
        return el;
    }

    function appendUserMsg(text, animate = true) {
        const el = document.createElement('div');
        el.className = 'msg user-msg' + (animate ? ' scale-in' : '');
        el.innerHTML = `<div class="bubble">${escHtml(text)}</div>`;
        chatMessages.appendChild(el);
        scrollToBottom();
        return el;
    }

    function scrollToBottom() {
        chatMessages.scrollTop = chatMessages.scrollHeight;
    }

    // ----------------------------------------------------------------
    // CHAT POPUP OPEN / CLOSE
    // ----------------------------------------------------------------
    chatFab.addEventListener('click', openChat);
    closeChatBtn.addEventListener('click', closeChat);

    function openChat() {
        ensureDefaultChat();
        chatPopup.style.display = 'flex';
        chatPopup.classList.remove('closing');
        chatOpen = true;
        fabBadge.style.display = 'none';
        renderMessages();
        setTimeout(() => chatInput.focus(), 100);
    }

    function closeChat() {
        chatPopup.classList.add('closing');
        setTimeout(() => {
            chatPopup.style.display = 'none';
            chatPopup.classList.remove('closing');
            chatOpen = false;
        }, 280);
    }

    // ----------------------------------------------------------------
    // SIDEBAR OPEN / CLOSE
    // ----------------------------------------------------------------
    openSidebarBtn.addEventListener('click', openSidebar);
    popupSidebarBtn.addEventListener('click', openSidebar);
    closeSidebarBtn.addEventListener('click', closeSidebar);
    sidebarOverlay.addEventListener('click', closeSidebar);

    function openSidebar() { sidebar.classList.add('open'); sidebarOverlay.classList.add('open'); renderChatList(); }
    function closeSidebar() { sidebar.classList.remove('open'); sidebarOverlay.classList.remove('open'); }

    newChatBtn.addEventListener('click', () => { closeSidebar(); createChat(true); });

    // ----------------------------------------------------------------
    // MOOD SELECTION (home page)
    // ----------------------------------------------------------------
    moodRow.querySelectorAll('.mood-pill').forEach(btn => {
        btn.addEventListener('click', () => {
            moodRow.querySelectorAll('.mood-pill').forEach(b => b.classList.remove('selected'));
            btn.classList.add('selected');
            const mood = btn.getAttribute('data-mood');
            const msg  = btn.getAttribute('data-msg');
            currentMoodText.textContent = `${btn.textContent.trim()}`;
            currentMoodDisplay.style.display = 'inline-flex';
            // Auto-send to chat
            openChat();
            sendMessage(msg);
        });
    });

    // ----------------------------------------------------------------
    // QUICK ACTION CARDS (home page)
    // ----------------------------------------------------------------
    quickCards.forEach(card => {
        card.addEventListener('click', () => {
            const msg = card.getAttribute('data-msg');
            openChat();
            sendMessage(msg);
        });
    });

    // ----------------------------------------------------------------
    // HUMAN-LIKE MULTI-LAYER REPLY ENGINE  v2
    // Format: empathy line → personal/question line → follow-up line
    // All combined into one flowing 3-line natural reply
    // ----------------------------------------------------------------

    const LAYERS = {
